+/* Copyright (c) 2026 Richard Rodger and other contributors, MIT License */
+
+/*  builtins.ts
+ *  Standard `$`-suffixed builtin function references.
+ *
+ *  A trailing `$` in a ref name marks an engine-provided builtin. The
+ *  `$` ref-namespace is reserved (user grammars must not define refs
+ *  containing `$`). These functions are merged into the effective ref
+ *  map at `grammar()` load time, so a *serialized* (function-free)
+ *  GrammarSpec can reference them purely by name — the wire format
+ *  carries strings like `@probeInit$`, not closures.
+ *
+ *  Probe + phase-retry dispatch (optional-prefix `[X D] Y` ambiguity)
+ *  ----------------------------------------------------------------
+ *  The dispatcher rule retries itself across three phases stored in
+ *  `r.k.pd_phase` (0 = probe, 1 = saw disambiguator, 2 = did not).
+ *  Phase 0 marks the position and runs a failure-proof probe; its
+ *  close peeks the next token, rewinds, and picks phase 1 or 2. The
+ *  disambiguator token name rides in `k.pd_d` on the phase-0 open alt
+ *  (propagated into `r.k`). These builtins are generic — all grammar-
+ *  specific data is config, never closed-over state.
+ */
+
+import type { Rule, Context } from './types'
+
+
+// Output AST node shape produced by the @tabnas/bnf tree builtins:
+// `{rule?, src, kids}`. `user` rules carry a `rule` tag; `core` /
+// `helper` rules omit it so they flatten into the enclosing user node.
+function mkNode(rule: string | undefined, kind: string | undefined): any {
+  return 'user' === kind ? { rule, src: '', kids: [] } : { src: '', kids: [] }
+}
+
+
+export const BUILTIN_REFS: Record<string, Function> = {
+
+  // ---- Tree builders (config in `alt.k.<name>`) -------------------
+  // These mirror @tabnas/bnf's emitter closures so a serialized,
+  // function-free grammar builds the identical `{rule,src,kids}` tree.
+
+  // Allocate (when `init`) and/or accumulate matched terminals' src.
+  // Config `node$: { init?, rule?, kind?, nterms? }`.
+  '@node$': (r: Rule, _ctx: any, alt: any) => {
+    const cfg = (alt && alt.k && alt.k.node$) || {}
+    if (cfg.init) r.node = mkNode(cfg.rule, cfg.kind)
+    const n = r.node as any
+    const nterms = cfg.nterms || 0
+    for (let i = 0; i < nterms; i++) n.src += r.o[i].src
+  },
+
+  // Merge the just-returned child node into the current node. Tagged
+  // children push into `kids`; untagged ones flatten (src concatenates,
+  // kids extend). Config `capture$: { rule?, kind? }`.
+  '@capture$': (r: Rule, _ctx: any, alt: any) => {
+    const cfg = (alt && alt.k && alt.k.capture$) || {}
+    if (null == r.node) r.node = mkNode(cfg.rule, cfg.kind)
+    const n = r.node as any
+    const c = r.child && (r.child.node as any)
+    if (null == c) return
+    if ('object' !== typeof c || !('src' in c)) { n.kids.push(c); return }
+    if (c === n) return
+    n.src += c.src
+    if (c.rule) n.kids.push(c)
+    else if (Array.isArray(c.kids)) n.kids.push(...c.kids)
+  },
+
+  // Lift the committed child's node straight up (no merge).
+  '@bubble$': (r: Rule) => {
+    if (r.child && (r.child.node as any) !== undefined) r.node = r.child.node
+  },
+
+  // ---- Probe + phase-retry dispatch -------------------------------
+  // Phase-0 open action: mark the token position and reset phase.
+  '@probeInit$': (r: Rule, ctx: any) => {
+    r.k.pd_phase = 0
+    r.k.pd_mark = ctx.mark()
+  },
+
+  // Phase-0 close action: peek the first token the probe did not
+  // consume, rewind to the mark, and commit to phase 1 (disambiguator
+  // present) or phase 2 (absent). The probe never fails, so `ctx.t[0]`
+  // always reflects a real position.
+  '@probeDecide$': (r: Rule, ctx: any) => {
+    const peek = ctx.t[0]
+    ctx.rewind(r.k.pd_mark)
+    r.k.pd_phase = (peek && peek.name === r.k.pd_d) ? 1 : 2
+  },
+
+  // Phase-guard conditions.
+  '@probePhase0$': (r: Rule) => !r.k.pd_phase,
+  '@probePhase1$': (r: Rule) => r.k.pd_phase === 1,
+  '@probePhase2$': (r: Rule) => r.k.pd_phase === 2,
+}
