{
  "name": "@tabnas/bnf",
  "version": "0.1.0",
  "main": "dist/bnf.js",
  "type": "commonjs",
  "types": "dist/bnf.d.ts",
  "description": "BNF / ABNF grammar compiler for the tabnas parser.",
  "homepage": "https://github.com/rjrodger/tabnas-bnf",
  "keywords": [
    "tabnas",
    "bnf",
    "abnf",
    "grammar",
    "parser",
    "plugin"
  ],
  "author": "Richard Rodger (http://richardrodger.com)",
  "repository": {
    "type": "git",
    "url": "git://github.com/rjrodger/tabnas-bnf.git"
  },
  "scripts": {
    "test": "node --enable-source-maps --test test/**/*.test.js",
    "watch": "tsc --build src -w",
    "build": "tsc --build src",
    "clean": "rm -rf node_modules dist dist-test yarn.lock package-lock.json",
    "reset": "npm run clean && npm i && npm run build && npm test"
  },
  "license": "MIT",
  "files": [
    "dist",
    "bin",
    "LICENSE"
  ],
  "bin": {
    "tabnas-bnf": "bin/tabnas-bnf"
  },
  "exports": {
    ".": "./dist/bnf.js"
  },
  "peerDependencies": {
    "tabnas": "*"
  },
  "devDependencies": {
    "@types/node": "25.6.0",
    "tabnas": "*",
    "typescript": "6.0.3"
  }
}
